# Spotify API (required)
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Audiomack Data API (optional — third preview fallback after Spotify + iTunes)
# Register at https://audiomack.com/data-api/docs — OAuth 1.0a consumer key + secret.
# Leave blank to disable (app behaves exactly as before).
EXPO_PUBLIC_AUDIOMACK_CONSUMER_KEY=
EXPO_PUBLIC_AUDIOMACK_CONSUMER_SECRET=
# Optional HTTPS proxy you host — GET `${PROXY}/preview?track=&artist=` returns JSON `{ "url": "https://..." }` so secrets stay off-device.
EXPO_PUBLIC_AUDIOMACK_PROXY_URL=

# Firebase (required for auth + multiplayer)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
